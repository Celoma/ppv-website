# Configuration de la base de données
# Pour le développement local avec Docker, utilisez les valeurs du docker-compose.yml
# Pour Vercel, utilisez votre base de données Prisma Postgres : prisma-postgres-claret-pillow
# Copiez la valeur DATABASE_URL depuis le dashboard Prisma Postgres
DATABASE_URL=

# Alternative : configuration individuelle (Docker local)
DB_HOST=db
DB_PORT=5432
DB_USER=tasks_user
DB_PASSWORD=tasks_password
DB_NAME=tasks_db

# Configuration de l'IA
# Pour le développement local avec Ollama Docker, laissez OPENAI_API_KEY vide
# Pour Vercel, ajoutez votre clé API OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Clé API Ollama (si vous utilisez un service Ollama cloud ou distant)
OLLAMA_API_KEY=your_ollama_api_key_here

# Force l'utilisation d'OpenAI (true) ou Ollama (false/false)
# Si vide, utilise OpenAI si OPENAI_API_KEY est défini, sinon Ollama
USE_OPENAI=

# URL de Ollama pour le développement local (optionnel, par défaut http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Port du backend (optionnel, par défaut 4000)
PORT=4000

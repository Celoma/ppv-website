{
  "uid": "ppv-monitoring",
  "title": "PPV - Monitoring",
  "tags": ["ppv", "docker", "postgres", "backend"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "style": "dark",
  "editable": false,
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Conteneurs actifs",
      "id": 1,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": {
  "type": "prometheus",
  "uid": "ppv-prometheus"
},
      "targets": [
        {
          "expr": "count(container_last_seen{container_label_com_docker_compose_service!=\"\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "CPU des conteneurs",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "datasource": {
  "type": "prometheus",
  "uid": "ppv-prometheus"
},
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=\"\"}[5m]))",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "core"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Mémoire des conteneurs",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": {
  "type": "prometheus",
  "uid": "ppv-prometheus"
},
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (container_memory_working_set_bytes{container_label_com_docker_compose_service!=\"\"})",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "PostgreSQL disponible",
      "id": 4,
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "datasource": {
  "type": "prometheus",
  "uid": "ppv-prometheus"
},
      "targets": [
        {
          "expr": "pg_up",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Connexions PostgreSQL",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": {
  "type": "prometheus",
  "uid": "ppv-prometheus"
},
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"tasks_db\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Débit des requêtes applicatives",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": {
  "type": "prometheus",
  "uid": "ppv-prometheus"
},
      "targets": [
        {
          "expr": "sum by (route, method, status_code) (rate(ppv_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{route}} {{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Latence P95 de l'application",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": {
  "type": "prometheus",
  "uid": "ppv-prometheus"
},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ppv_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    }
  ]
}
